{
    "name": "syaptiyan/sirs",
    "description": "Sistem Informasi Rumah Sakit (SIRS) — Modern, modular, production-ready hospital information system built with CodeIgniter 4.",
    "license": "MIT",
    "type": "project",
    "homepage": "https://github.com/Syaptiyan/sirs",
    "support": {
        "issues": "https://github.com/Syaptiyan/sirs/issues",
        "source": "https://github.com/Syaptiyan/sirs"
    },
    "require": {
        "php": "^8.2",
        "codeigniter4/framework": "^4.7",
        "codeigniter4/shield": "^1.3",
        "mpdf/mpdf": "^8.2",
        "phpmailer/phpmailer": "^6.9"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9",
        "mikey179/vfsstream": "^1.6",
        "phpunit/phpunit": "^10.5.16"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "app/Config/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/_support"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit"
    }
}
