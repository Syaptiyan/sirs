#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
# production, development, testing
CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'http://localhost:8080'
app.forceGlobalSecureRequests = true
app.CSPEnabled = true

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

# PostgreSQL (production)
database.default.hostname = localhost
database.default.database = sirs
database.default.username = postgres
database.default.password = secret
database.default.DBDriver = PostgreSQL
database.default.port = 5432

# SQLite3 (development)
# database.default.database = writable/sirs.sqlite
# database.default.DBDriver = SQLite3

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------
# Generate with: php -r "echo bin2hex(random_bytes(32));"
encryption.key =

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------
# Redis handler recommended for production / multi-server setup
session.driver = 'CodeIgniter\Session\Handlers\RedisHandler'
session.savePath = 'tcp://localhost:6379?timeout=5&prefix=sirs_session_'
session.cookieSecure = true
session.cookieSameSite = 'Strict'
session.cookieDomain =

#--------------------------------------------------------------------
# CACHE
#--------------------------------------------------------------------

cache.redis.host = localhost
cache.redis.password =
cache.redis.port = 6379

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------

logger.threshold = 4
